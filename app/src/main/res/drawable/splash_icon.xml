<?xml version="1.0" encoding="utf-8"?>
<!--
    Wrapper drawable for the SplashScreen API.
    Using a layer-list with gravity="center" prevents the PNG from being
    stretched to fit the 288dp×288dp splash screen icon area, preserving
    the logo's natural aspect ratio.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <bitmap
            android:src="@drawable/logo"
            android:gravity="center" />
    </item>
</layer-list>
