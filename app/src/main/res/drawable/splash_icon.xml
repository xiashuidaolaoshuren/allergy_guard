<?xml version="1.0" encoding="utf-8"?>
<!--
    Wrapper drawable for the SplashScreen API.
    The SplashScreen API clips the icon with a circular mask (like adaptive icons).
    We use android:inset="20%" to shrink the logo so the entire image fits inside
    the inscribed circle, preventing any part of the logo from being cropped.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:inset="20%">
        <bitmap
            android:src="@drawable/logo"
            android:gravity="center" />
    </item>
</layer-list>
